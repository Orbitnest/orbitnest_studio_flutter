# OrbitNest Studio Flutter SDK — Configuration
# Copy this file to .env and fill in your values.
#
# The project slug and project URL are embedded inside the anon key JWT and
# resolved at runtime — you do NOT need to set them separately.

# Your project's anonymous key (from OrbitNest Studio → Settings → API Keys)
ORBITNEST_ANON_KEY=your_anon_key_here

# Enable verbose SDK logging (set false / remove for production)
ORBITNEST_DEBUG=false

# HTTP timeout in milliseconds (default: 180000 — 3 minutes)
# ORBITNEST_API_TIMEOUT=180000

# Override the API base URL — only needed for local development
# ORBITNEST_API_URL=http://localhost:3002
