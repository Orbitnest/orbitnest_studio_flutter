# OrbitNest Studio Configuration
# Copy this file to .env and fill in your project details

# Base URL of your OrbitNest Studio instance
ORBITNEST_BASE_URL=http://localhost:3001

# Your project slug from OrbitNest Studio
ORBITNEST_PROJECT_SLUG=your-project-slug

# Your project's anonymous key
ORBITNEST_ANON_KEY=your-anon-key

# Your project's service role key (optional, for admin operations)
ORBITNEST_SERVICE_ROLE_KEY=your-service-role-key

# Project ID (optional, defaults to project slug)
ORBITNEST_PROJECT_ID=your-project-id

# Enable debug mode for detailed logging
ORBITNEST_DEBUG=false

# API timeout in milliseconds
ORBITNEST_API_TIMEOUT=30000